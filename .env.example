# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Green API - Driver/Admin messaging (used by api/drivers-messaging.js and api/webhook.mjs)
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token
# Chat ID for driver dispatch WhatsApp notifications (format: PHONENUMBER@c.us)
GREEN_API_CHAT_ID=201xxxxxxxxx@c.us
# Group chat ID for admin/webhook notifications (format: GROUPID@g.us)
GREEN_API_GROUP_CHAT_ID=your_group_id@g.us

# Green API - Customer order notifications (used by api/order.js)
GREEN_API_ORDER_INSTANCE_ID=your_order_instance_id
GREEN_API_ORDER_TOKEN=your_order_api_token
GREEN_API_ORDER_CHAT_ID=201xxxxxxxxx@c.us

# Shopify
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# Admin API Key — protects dispatch endpoints from unauthorized access
# Generate with: openssl rand -base64 32
# Must be prefixed with NEXT_PUBLIC_ to be accessible in frontend
NEXT_PUBLIC_ADMIN_API_KEY=your_random_api_key_here

# Cron secret — protects /api/reconcile from public access
CRON_SECRET=your_random_secret_here
